{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForecastRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["feature_version", "bucket_end", "target", "history_rps", "features"],
  "properties": {
    "feature_version": {"type": "string", "minLength": 1},
    "bucket_end": {"type": "string", "format": "date-time"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "endpoint"],
      "properties": {
        "scope": {"type": "string", "enum": ["system", "endpoint"]},
        "endpoint": {"type": "string"}
      }
    },
    "history_rps": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "integer", "minimum": 0}
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rolling_mean_5", "rolling_std_5", "hour_of_day", "day_of_week"],
      "properties": {
        "rolling_mean_5": {"type": "number", "minimum": 0},
        "rolling_std_5": {"type": "number", "minimum": 0},
        "hour_of_day": {"type": "integer", "minimum": 0, "maximum": 23},
        "day_of_week": {"type": "integer", "minimum": 0, "maximum": 6}
      }
    }
  }
}
