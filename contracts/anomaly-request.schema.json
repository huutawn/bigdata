{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnomalyRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["feature_version", "window_start", "window_end", "entity", "features"],
  "properties": {
    "feature_version": {"type": "string", "minLength": 1},
    "window_start": {"type": "string", "format": "date-time"},
    "window_end": {"type": "string", "format": "date-time"},
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint"],
      "properties": {
        "endpoint": {"type": "string", "minLength": 1}
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_count",
        "avg_latency_ms",
        "p95_latency_ms",
        "p99_latency_ms",
        "status_5xx_ratio",
        "baseline_avg_latency_ms",
        "baseline_5xx_ratio"
      ],
      "properties": {
        "request_count": {"type": "integer", "minimum": 0},
        "avg_latency_ms": {"type": "number", "minimum": 0},
        "p95_latency_ms": {"type": "number", "minimum": 0},
        "p99_latency_ms": {"type": "number", "minimum": 0},
        "status_5xx_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "baseline_avg_latency_ms": {"type": "number", "minimum": 0},
        "baseline_5xx_ratio": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
