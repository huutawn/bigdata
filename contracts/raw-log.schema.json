{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawLog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestamp",
    "ip",
    "endpoint",
    "status",
    "request_time_ms",
    "user_agent"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "ip": {
      "type": "string",
      "minLength": 7
    },
    "endpoint": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "request_time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "user_agent": {
      "type": "string",
      "minLength": 1
    }
  }
}
