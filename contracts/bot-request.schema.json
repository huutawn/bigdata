{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BotRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["feature_version", "window_start", "window_end", "entity", "features"],
  "properties": {
    "feature_version": {"type": "string", "minLength": 1},
    "window_start": {"type": "string", "format": "date-time"},
    "window_end": {"type": "string", "format": "date-time"},
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ip", "session_id", "user_agent"],
      "properties": {
        "ip": {"type": "string", "minLength": 7},
        "session_id": {"type": "string", "minLength": 1},
        "user_agent": {"type": "string", "minLength": 1}
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number_of_requests",
        "total_duration_s",
        "average_time_ms",
        "repeated_requests",
        "http_response_2xx",
        "http_response_3xx",
        "http_response_4xx",
        "http_response_5xx",
        "get_method",
        "post_method",
        "head_method",
        "other_method",
        "night",
        "max_barrage"
      ],
      "properties": {
        "number_of_requests": {"type": "integer", "minimum": 0},
        "total_duration_s": {"type": "number", "minimum": 0},
        "average_time_ms": {"type": "number", "minimum": 0},
        "repeated_requests": {"type": "number", "minimum": 0, "maximum": 1},
        "http_response_2xx": {"type": "number", "minimum": 0, "maximum": 1},
        "http_response_3xx": {"type": "number", "minimum": 0, "maximum": 1},
        "http_response_4xx": {"type": "number", "minimum": 0, "maximum": 1},
        "http_response_5xx": {"type": "number", "minimum": 0, "maximum": 1},
        "get_method": {"type": "number", "minimum": 0, "maximum": 1},
        "post_method": {"type": "number", "minimum": 0, "maximum": 1},
        "head_method": {"type": "number", "minimum": 0, "maximum": 1},
        "other_method": {"type": "number", "minimum": 0, "maximum": 1},
        "night": {"type": "integer", "enum": [0, 1]},
        "max_barrage": {"type": "integer", "minimum": 0}
      }
    }
  }
}
